<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/ongil_surface"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:contentDescription="온길 귀가 도우미 온이"
            android:src="@drawable/ic_oni_pet" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="온이 · 귀가 도우미"
                android:textColor="@color/ongil_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="상황을 이해하고 알맞은 온길 기능을 열어줘요"
                android:textColor="@color/ongil_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/oniReplyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_map_label"
        android:lineSpacingExtra="3dp"
        android:padding="16dp"
        android:text="오늘은 픽업이야, 혼자 가?"
        android:textColor="@color/ongil_text"
        android:textSize="15sp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quickPickupButton"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="엄마가 데리러 와"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quickSoloButton"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:text="오늘 혼자 가"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quickShareButton"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:text="위치 공유할래"
                app:cornerRadius="14dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/oniMessageInput"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_map_label"
            android:hint="예: 밤길이 무서워"
            android:imeOptions="actionSend"
            android:inputType="textCapSentences"
            android:maxLines="2"
            android:paddingHorizontal="14dp"
            android:textColor="@color/ongil_text"
            android:textColorHint="@color/ongil_text_muted" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/oniSendButton"
            android:layout_width="72dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:text="보내기"
            app:cornerRadius="16dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="온이는 기능을 안내하며 경로나 안전 점수를 만들지 않아요. 위치 공유는 확인 후 시작됩니다."
        android:textColor="@color/ongil_text_muted"
        android:textSize="11sp" />
</LinearLayout>
