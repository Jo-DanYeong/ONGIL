<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ongil_surface"
    tools:context=".RoutePlansActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/ongil_text"
            android:textSize="34sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="야간에는 어떤 길이 안전할까요?"
            android:textColor="@color/ongil_text"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="도착 시간뿐 아니라 밝기와 도움을 요청할 수 있는 장소도 비교해요."
            android:textColor="@color/ongil_text_secondary"
            android:textSize="15sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ongil_primary"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/planATitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_green"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:text="온길 추천"
                    android:textColor="@color/ongil_success_dark"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="플랜 A · 야간 안전 우선"
                    android:textColor="@color/ongil_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/planAMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="15분 · 야간 안전 점수 78"
                    android:textColor="@color/ongil_success_dark"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/planAProgress"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="14dp"
                    android:max="100"
                    android:progress="78"
                    app:indicatorColor="@color/ongil_success"
                    app:trackColor="@color/ongil_success_light"
                    app:trackCornerRadius="4dp"
                    app:trackThickness="8dp" />

                <TextView
                    android:id="@+id/planAFactors"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="4dp"
                    android:text="✓ 밝은 길 구간 84%\n✓ 편의점·파출소 등 안전 거점 4곳\n✓ 어두운 골목 없이 이동"
                    android:textColor="@color/ongil_text_secondary"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/planAButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="18dp"
                    android:text="플랜 A로 안내 시작"
                    app:cornerRadius="16dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ongil_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/planBTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="플랜 B · 빠른 길"
                    android:textColor="@color/ongil_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/planBMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="10분 · 야간 안전 점수 42"
                    android:textColor="@color/ongil_warning_dark"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/planBProgress"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="14dp"
                    android:max="100"
                    android:progress="42"
                    app:indicatorColor="@color/ongil_warning"
                    app:trackColor="@color/ongil_warning_light"
                    app:trackCornerRadius="4dp"
                    app:trackThickness="8dp" />

                <TextView
                    android:id="@+id/planBFactors"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="4dp"
                    android:text="✓ 5분 빠른 도착\n△ 밝은 길 구간 48%\n△ 안전 거점 1곳 · 어두운 골목 2곳"
                    android:textColor="@color/ongil_text_secondary"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/planBButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="18dp"
                    android:text="플랜 B 선택"
                    app:cornerRadius="16dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="온길은 골목 단위 범죄를 예측하지 않습니다. 가로등 · 안전 거점 · 시간대 · 교통 혼잡을 조합한 야간 안전 우선 경로입니다."
            android:textColor="@color/ongil_text_muted"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
